# Copy to .env (never commit .env). python-decouple reads OS env first, then .env.

DEBUG=True
SECRET_KEY=change-me-use-a-long-random-string-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# --- SQLite (default for local pipenv): leave all DB_* unset or commented ---
# --- Docker Compose: uncomment and match docker-compose / Postgres service ---
# DB_NAME=deployment_db
# DB_USER=deployment_user
# DB_PASSWORD=deployment_pass_change_me
# DB_HOST=db
# DB_PORT=5432
