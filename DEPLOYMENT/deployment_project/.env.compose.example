# Copy to .env when using Docker Compose (Postgres + web).
# Compose substitutes ${DB_NAME} etc. in docker-compose.yml from this file.

DEBUG=True
SECRET_KEY=change-me-use-a-long-random-string-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=deployment_db
DB_USER=deployment_user
DB_PASSWORD=deployment_pass_change_me
DB_HOST=db
DB_PORT=5432
